{
  "name": "hello-ledger",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "postCreateCommand": "pip install -r requirements.txt",
  "postAttachCommand": {
    "app": "streamlit run app.py --server.headless true"
  },
  "forwardPorts": [8501],
  "portsAttributes": {
    "8501": {
      "label": "hello-ledger app",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
